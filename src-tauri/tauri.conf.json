{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NanoWhisper",
  "version": "0.1.24",
  "identifier": "com.nanowhisper.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist",
      "dmg": {
        "background": "dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    },
    "windows": {
      "signCommand": "nanowhisper-sign.cmd %1"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwNUUzQ0NENThFNTI2MTUKUldRVkp1Vll6VHhlb0NsN094NFQvVk9NOVVBYUVKNkpzUHVIME1nQjk2amhRUmVpYk9ZeTRpencK",
      "endpoints": [
        "https://github.com/jicaiinc/nanowhisper/releases/latest/download/latest.json"
      ]
    }
  }
}
